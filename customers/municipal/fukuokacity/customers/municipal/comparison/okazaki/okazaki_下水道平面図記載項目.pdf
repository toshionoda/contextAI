/* --- チャットボタン --- */
.chat-fab {
position: fixed;
z-index: 1000 !important;
display: inline-flex;
align-items: center;
gap: 1rem;
text-decoration: none;
cursor: pointer;
bottom: 130px;
right: 10px;
background: #ffeef7;
color: #000;
padding: 0.8rem 1.6rem;
font-size: 1rem;
border-radius: 99.9rem;
border: .1rem solid rgba(0, 0, 0, 0.15);
font-weight: 600;
box-shadow: 0 2rem 4rem rgba(0, 0, 0, 0.28);
transition: transform 0.3s ease, box-shadow 0.3s ease;
}
.chat-fab:hover { background: #FFF8D1; color: #333; }
.chat-fab:active { background: #FFF8D1; color: #333; }
.chat-fab-img { height: 2.4rem; width: auto; margin-right: .5rem; aspect-ratio: 1 / 1; }
.chat-fab__text { white-space: nowrap; }
/* --- チャットボタン（開いている時） --- */
.chat-fab.chat-open { transform: scale(0.9); }
.chat-fab.chat-open .chat-fab-img { height: 3.0rem; }
/* --- チャットウィンドウ --- */
.custom-chat-window {
position: fixed; right: 24px; bottom: 200px; z-index: 9999;
opacity: 0; visibility: hidden; transform: translateY(20px);
transition: all 0.3s ease-in-out;
}
.custom-chat-window.open { opacity: 1; visibility: visible; transform: translateY(0); }
.chat-frame-container {
width: 375px; height: 600px; max-height: calc(100vh - 250px);
background-color: #fff; border-radius: 10px;
box-shadow: 0 5px 24px rgba(0, 0, 0, 0.2); overflow: hidden; border: 1px solid #ddd;
}
.chat-frame { width: 100%; height: 100%; border: none; display: block; }
/* --- モバイル対応 --- */
@media (max-width: 480px) {
.chat-fab {
padding: 5px 12px 5px 10px !important;
right: 8px !important;
font-size: 0.75rem !important;
gap: 0.4rem !important;
}
.chat-fab-img { height: 1.6rem !important; margin-right: 0 !important; }
.chat-fab__text span { font-size: 0.75rem !important; }
.custom-chat-window {
right: 0 !important; top: 0 !important; bottom: auto !important;
width: 100% !important; height: calc(100vh - 180px) !important;
}
.chat-frame-container {
width: 100% !important; height: 100% !important;
max-height: none !important; border-radius: 0 !important;
}
}
