<!-- チャットボタン -->
<a class="chat-fab" id="chat" onclick="toggleChat(event)">
<img src="https://cdp.city.okazaki.lg.jp/sn_nava_config.okazaemon_close_btn.png" alt="" class="chat-fab-img">
<span class="chat-fab__text">
<span id="chat-btn-text">チャットでお問い合わせ</span>
</span>
</a>
<!-- チャットウィンドウ -->
<div class="custom-chat-window" id="chat-window">
<div class="chat-frame-container">
<iframe id="chat-frame" class="chat-frame" src="" allow="microphone" title="チャットボット"></iframe>
</div>
</div>
<!-- JS -->
<script>
var chatOpen = false;
var chatLoaded = false;
var chatUrl = 'https://cdp.city.okazaki.lg.jp/x_okac2_hp_hp_va_translate_wrapper.do'
+ '?sysparm_portal_id=2d35c60a2bd936104461f77ace91bf91'
+ '&sysparm_branding_key=now_assist_in_va'
+ '&sysparm_external=true';
function toggleChat(event) {
event.preventDefault();
var chatWindow = document.getElementById('chat-window');
var chatBtn = document.getElementById('chat');
var chatBtnText = document.getElementById('chat-btn-text');
if (!chatOpen) {
if (!chatLoaded) {
document.getElementById('chat-frame').src = chatUrl;
chatLoaded = true;
}
chatWindow.classList.add('open');
chatBtn.classList.add('chat-open');
chatBtnText.textContent = 'とじる';
chatOpen = true;
} else {
chatWindow.classList.remove('open');
chatBtn.classList.remove('chat-open');
chatBtnText.textContent = 'チャットでお問い合わせ';
chatOpen = false;
}
}
</script>
